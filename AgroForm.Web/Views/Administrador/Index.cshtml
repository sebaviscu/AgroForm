    <script>
        // Manejo del tema
        $(document).ready(function() {
            const themeSwitch = document.getElementById('themeSwitch');
            const body = document.body;
            
            // Cargar tema guardado (por defecto dark)
            const savedTheme = localStorage.getItem('theme') || 'dark';
            if (savedTheme === 'dark') {
                body.setAttribute('data-theme', 'dark');
                themeSwitch.checked = true;
            } else {
                body.removeAttribute('data-theme');
                themeSwitch.checked = false;
            }
            
            // Manejar cambio de tema
            themeSwitch.addEventListener('change', function() {
                if (this.checked) {
                    body.setAttribute('data-theme', 'dark');
                    localStorage.setItem('theme', 'dark');
                } else {
                    body.removeAttribute('data-theme');
                    localStorage.setItem('theme', 'light');
                }
                
                // Refrescar DataTables para aplicar nuevo tema
                if (typeof tableCultivos !== 'undefined') {
                    tableCultivos.draw();
                }
                if (typeof tableVariedades !== 'undefined') {
                    tableVariedades.draw();
                }
                if (typeof tableLicencias !== 'undefined') {
                    tableLicencias.draw();
                }
                if (typeof tableCatalogos !== 'undefined') {
                    tableCatalogos.draw();
                }
            });
        });
    </script>

