@{
    ViewData["Title"] = "Configuración";
}

<style>
    .config-section-title {
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--bs-primary);
        margin-bottom: 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--bs-primary);
    }

    .config-item {
        display: flex;
        align-items: center;
        padding: 0.5rem 0.75rem;
        border-radius: 0.375rem;
        transition: background-color 0.15s ease;
    }

    .config-item:hover {
        background-color: rgba(var(--bs-primary-rgb), 0.05);
    }

    .config-item .form-check {
        margin-bottom: 0;
        min-height: auto;
    }

    .config-item .form-check-input {
        cursor: pointer;
        width: 1.1rem;
        height: 1.1rem;
    }

    .config-item .form-check-input:checked {
        background-color: var(--bs-primary);
        border-color: var(--bs-primary);
    }

    .config-item-label {
        font-size: 0.9rem;
        font-weight: 500;
        margin-left: 0.5rem;
        flex: 1;
    }

    .config-item-badge {
        font-size: 0.7rem;
        font-weight: 400;
        padding: 0.15rem 0.4rem;
        border-radius: 0.25rem;
        margin-left: 0.5rem;
    }

    .crop-group {
        margin-bottom: 0.5rem;
    }

    .crop-header {
        display: flex;
        align-items: center;
        padding: 0.4rem 0.5rem;
        background-color: rgba(var(--bs-secondary-rgb), 0.05);
        border-radius: 0.375rem 0.375rem 0 0;
        cursor: pointer;
        transition: background-color 0.15s ease;
        user-select: none;
    }

    .crop-header:hover {
        background-color: rgba(var(--bs-secondary-rgb), 0.1);
    }

    .crop-header .expand-icon {
        transition: transform 0.2s ease;
        margin-right: 0.4rem;
        font-size: 0.85rem;
    }

    .crop-header .expand-icon.expanded {
        transform: rotate(90deg);
    }

    .crop-header .crop-orden {
        font-size: 0.75rem;
        color: var(--bs-secondary);
        margin-left: 0.3rem;
        font-weight: 400;
        white-space: nowrap;
    }

    .edit-item-btn {
        background: none;
        border: none;
        color: var(--bs-secondary);
        cursor: pointer;
        padding: 0.15rem 0.35rem;
        border-radius: 0.25rem;
        font-size: 0.85rem;
        opacity: 0.5;
        transition: opacity 0.15s ease, color 0.15s ease;
        margin-left: 0.25rem;
    }

    .edit-item-btn:hover {
        opacity: 1;
        color: var(--bs-primary);
        background-color: rgba(var(--bs-primary-rgb), 0.08);
    }

    /* Two-column grid for cultivo items */
    .cultivo-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.25rem 1rem;
    }

    @@media (max-width: 768px) {
        .cultivo-grid {
            grid-template-columns: 1fr;
        }
    }

    .estados-container {
        padding-left: 2.5rem;
        border-left: 2px solid rgba(var(--bs-secondary-rgb), 0.15);
        margin-left: 1.6rem;
        margin-bottom: 0.5rem;
    }

    .estado-item {
        display: flex;
        align-items: center;
        padding: 0.3rem 0.5rem;
        border-radius: 0.25rem;
        transition: background-color 0.15s ease;
    }

    .estado-item:hover {
        background-color: rgba(var(--bs-secondary-rgb), 0.05);
    }

    .estado-item .form-check-input {
        cursor: pointer;
        width: 0.95rem;
        height: 0.95rem;
    }

    .estado-item .form-check-input:checked {
        background-color: var(--bs-success);
        border-color: var(--bs-success);
    }

    .estado-item-label {
        font-size: 0.85rem;
        margin-left: 0.4rem;
    }

    .add-estado-btn {
        font-size: 0.8rem;
        padding: 0.15rem 0.5rem;
        margin-top: 0.25rem;
        margin-left: 0.5rem;
    }

    .tipo-filter-group {
        margin-bottom: 1rem;
    }

    .tipo-filter-select {
        max-width: 300px;
    }

    .catalogo-tipo-group {
        margin-bottom: 1rem;
    }

    .catalogo-tipo-title {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--bs-primary);
        padding: 0.35rem 0.75rem;
        background-color: rgba(var(--bs-primary-rgb), 0.05);
        border-radius: 0.375rem;
        margin-bottom: 0.25rem;
    }

    /* Two-column grid for catalogo items */
    .catalogo-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.25rem 1rem;
    }

    @@media (max-width: 768px) {
        .catalogo-grid {
            grid-template-columns: 1fr;
        }
    }

    .catalogo-item {
        display: flex;
        align-items: center;
        padding: 0.3rem 0.5rem;
        border-radius: 0.25rem;
        transition: background-color 0.15s ease;
    }

    .catalogo-item:hover {
        background-color: rgba(var(--bs-secondary-rgb), 0.05);
    }

    .catalogo-item .form-check-input {
        cursor: pointer;
        width: 1rem;
        height: 1rem;
    }

    .catalogo-item .form-check-input:checked {
        background-color: var(--bs-primary);
        border-color: var(--bs-primary);
    }

    .catalogo-item-label {
        font-size: 0.85rem;
        font-weight: 500;
        margin-left: 0.4rem;
        flex: 1;
    }

    .loading-placeholder {
        text-align: center;
        padding: 2rem;
        color: var(--bs-secondary);
    }

    .tab-content {
        padding-top: 1rem;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">
            <i class="ph ph-sliders text-primary me-2"></i>Configuración
        </h1>
        <p class="text-muted mb-0">Gestione sus cultivos, estados fenológicos y catálogos</p>
    </div>
</div>

<!-- Tabs -->
<div class="card">
    <div class="card-header">
        <ul class="nav nav-tabs card-header-tabs" id="configTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="cultivos-tab" data-bs-toggle="tab"
                        data-bs-target="#cultivos" type="button" role="tab"
                        aria-controls="cultivos" aria-selected="true">
                    <i class="ph ph-tree me-2"></i>Cultivos y Estados Fenológicos
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="catalogos-tab" data-bs-toggle="tab"
                        data-bs-target="#catalogos" type="button" role="tab"
                        aria-controls="catalogos" aria-selected="false">
                    <i class="ph ph-list-checks me-2"></i>Catálogos
                </button>
            </li>
        </ul>
    </div>

    <div class="card-body">
        <div class="tab-content" id="configTabsContent">

            <!-- Tab Cultivos -->
            <div class="tab-pane fade show active" id="cultivos" role="tabpanel"
                 aria-labelledby="cultivos-tab" tabindex="0">

                <div id="cultivosLoading" class="loading-placeholder">
                    <div class="spinner-border text-primary mb-2" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <div>Cargando cultivos...</div>
                </div>

                <div id="cultivosContainer" style="display:none;">
                    <div id="cultivosList"></div>

                    <div class="mt-3">
                        <button id="btnNuevoCultivo" class="btn btn-primary">
                            <i class="ph ph-plus-circle me-2"></i>Nuevo Cultivo
                        </button>
                    </div>
                </div>

                <div id="cultivosEmpty" style="display:none;" class="text-center text-muted py-4">
                    <i class="ph ph-tree ph-2x mb-2" style="font-size: 2rem;"></i>
                    <p>No se encontraron cultivos disponibles.</p>
                </div>
            </div>

            <!-- Tab Catálogos -->
            <div class="tab-pane fade" id="catalogos" role="tabpanel"
                 aria-labelledby="catalogos-tab" tabindex="0">

                <div class="tipo-filter-group d-flex align-items-center gap-2">
                    <label for="tipoFilter" class="form-label mb-0 fw-medium">Filtrar por tipo:</label>
                    <select id="tipoFilter" class="form-select form-select-sm tipo-filter-select">
                        <option value="all">Todos los tipos</option>
                        <option value="10">Plaga</option>
                        <option value="11">Maleza</option>
                        <option value="12">Enfermedad</option>
                        <option value="20">Tipo Fertilizante</option>
                        <option value="21">Nutriente</option>
                        <option value="22">Producto Agroquímico</option>
                        <option value="30">Método de Siembra</option>
                        <option value="31">Método de Riego</option>
                        <option value="32">Método de Aplicación</option>
                        <option value="40">Maquinaria</option>
                        <option value="41">Fuente de Agua</option>
                        <option value="50">Laboratorio</option>
                        <option value="99">Otro</option>
                    </select>
                </div>

                <div id="catalogosLoading" class="loading-placeholder">
                    <div class="spinner-border text-primary mb-2" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <div>Cargando catálogos...</div>
                </div>

                <div id="catalogosContainer" style="display:none;">
                    <div id="catalogosList"></div>

                    <div class="mt-3">
                        <button id="btnNuevoCatalogo" class="btn btn-primary">
                            <i class="ph ph-plus-circle me-2"></i>Nuevo Catálogo
                        </button>
                    </div>
                </div>

                <div id="catalogosEmpty" style="display:none;" class="text-center text-muted py-4">
                    <i class="ph ph-list-checks ph-2x mb-2" style="font-size: 2rem;"></i>
                    <p>No se encontraron catálogos disponibles.</p>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Modal Cultivo (reusable: add / edit) -->
<div class="modal fade" id="modalCultivo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCultivoTitle">
                    <i class="ph ph-tree me-2"></i><span id="modalCultivoTitleText">Nuevo Cultivo</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="formCultivo">
                    <input type="hidden" id="cultivoEditId" value="">
                    <div class="mb-3">
                        <label for="cultivoNombre" class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="cultivoNombre" required maxlength="100"
                               placeholder="Ej: Quinoa">
                    </div>
                    <div class="mb-3">
                        <label for="cultivoDescripcion" class="form-label">Descripción</label>
                        <textarea class="form-control" id="cultivoDescripcion" rows="2" maxlength="500"
                                  placeholder="Descripción opcional del cultivo"></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="cultivoColor" class="form-label">Color (opcional)</label>
                        <input type="color" class="form-control form-control-color" id="cultivoColor"
                               value="#4CAF50" style="width: 60px; height: 38px; padding: 2px;">
                    </div>
                    <div class="mb-3">
                        <label for="cultivoOrden" class="form-label">Orden</label>
                        <input type="number" class="form-control" id="cultivoOrden" min="1" value="1"
                               style="width: 100px;">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnGuardarCultivo">
                    <i class="ph ph-check-circle me-1"></i> Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Nuevo Estado Fenológico -->
<div class="modal fade" id="modalNuevoEstadoFenologico" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ph ph-flower me-2"></i>Nuevo Estado Fenológico</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="formNuevoEstadoFenologico">
                    <input type="hidden" id="estadoIdCultivo">
                    <div class="mb-3">
                        <label class="form-label">Cultivo</label>
                        <p class="form-control-plaintext fw-medium" id="estadoCultivoNombre"></p>
                    </div>
                    <div class="mb-3">
                        <label for="estadoCodigo" class="form-label">Código <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="estadoCodigo" required maxlength="10"
                               placeholder="Ej: E, V6, R, F, M">
                    </div>
                    <div class="mb-3">
                        <label for="estadoNombre" class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="estadoNombre" required maxlength="100"
                               placeholder="Ej: Emergencia">
                    </div>
                    <div class="mb-3">
                        <label for="estadoDescripcion" class="form-label">Descripción</label>
                        <textarea class="form-control" id="estadoDescripcion" rows="2" maxlength="500"
                                  placeholder="Descripción opcional"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnGuardarEstadoFenologico">
                    <i class="ph ph-check-circle me-1"></i> Guardar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Catálogo (reusable: add / edit) -->
<div class="modal fade" id="modalCatalogo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCatalogoTitle">
                    <i class="ph ph-list-checks me-2"></i><span id="modalCatalogoTitleText">Nuevo Catálogo</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="formCatalogo">
                    <input type="hidden" id="catalogoEditId" value="">
                    <div class="mb-3">
                        <label for="catalogoTipo" class="form-label">Tipo <span class="text-danger">*</span></label>
                        <select class="form-select" id="catalogoTipo" required>
                            <option value="">Seleccione un tipo...</option>
                            <option value="10">Plaga</option>
                            <option value="11">Maleza</option>
                            <option value="12">Enfermedad</option>
                            <option value="20">Tipo Fertilizante</option>
                            <option value="21">Nutriente</option>
                            <option value="22">Producto Agroquímico</option>
                            <option value="30">Método de Siembra</option>
                            <option value="31">Método de Riego</option>
                            <option value="32">Método de Aplicación</option>
                            <option value="40">Maquinaria</option>
                            <option value="41">Fuente de Agua</option>
                            <option value="50">Laboratorio</option>
                            <option value="99">Otro</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="catalogoNombre" class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="catalogoNombre" required maxlength="100"
                               placeholder="Nombre del catálogo">
                    </div>
                    <div class="mb-3">
                        <label for="catalogoDescripcion" class="form-label">Descripción</label>
                        <textarea class="form-control" id="catalogoDescripcion" rows="2" maxlength="500"
                                  placeholder="Descripción opcional"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnGuardarCatalogo">
                    <i class="ph ph-check-circle me-1"></i> Guardar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/views/configuracion.js" asp-append-version="true"></script>
}
