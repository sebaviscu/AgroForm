@{
    ViewData["Title"] = "Mi Licencia";
}

<style>
    .licencia-card {
        transition: box-shadow 0.2s ease;
    }
    .licencia-card:hover {
        box-shadow: 0 0.25rem 0.75rem rgba(0,0,0,0.08);
    }
    .licencia-label {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.4px;
        color: var(--bs-secondary);
        margin-bottom: 0.2rem;
    }
    .licencia-value {
        font-size: 1rem;
        font-weight: 600;
    }
    .licencia-value-lg {
        font-size: 1.25rem;
        font-weight: 700;
    }
    .info-card-icon {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        font-size: 1.25rem;
    }
    .section-title {
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--bs-primary);
        margin-bottom: 0;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--bs-primary);
    }
    .loading-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
    }
    .error-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 3rem 1rem;
        color: var(--bs-danger);
    }
    .badge-license {
        font-size: 0.8rem;
        padding: 0.35rem 0.65rem;
    }

    /* Dark theme adjustments */
    [data-theme="dark"] .licencia-card {
        background-color: var(--bs-dark);
        border-color: var(--bs-gray-700);
    }
    [data-theme="dark"] .licencia-card .card {
        background-color: rgba(255,255,255,0.03);
        border-color: var(--bs-gray-700);
    }
</style>

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">
                <i class="ph ph-identification-card text-primary me-2"></i>Mi Licencia
            </h1>
            <p class="text-muted mb-0">Información de su licencia y pagos realizados</p>
        </div>
    </div>

    <!-- Loading State -->
    <div id="licenciaLoading" class="loading-container">
        <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="text-muted mb-0">Cargando información de licencia...</p>
    </div>

    <!-- Error State -->
    <div id="licenciaError" class="error-container" style="display:none;">
        <i class="ph ph-warning-circle" style="font-size: 3rem; margin-bottom: 0.75rem;"></i>
        <h5 class="fw-bold mb-2">Error al cargar datos</h5>
        <p id="licenciaErrorMessage" class="text-muted mb-3 text-center">No se pudieron obtener los datos de la licencia.</p>
        <button class="btn btn-primary" onclick="cargarDatosLicencia()">
            <i class="ph ph-arrows-clockwise me-2"></i>Reintentar
        </button>
    </div>

    <!-- Content -->
    <div id="licenciaContent" style="display:none;">

        <!-- License Info Cards -->
        <div class="card shadow-sm mb-4 licencia-card">
            <div class="card-body">
                <h5 class="section-title mb-4">
                    <i class="ph ph-info me-2"></i>Datos de la Licencia
                </h5>

                <div class="row g-3">
                    <!-- Tipo de Licencia -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light">
                            <div class="info-card-icon bg-primary bg-opacity-10 text-primary">
                                <i class="ph ph-seal-check"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="licencia-label">Tipo</div>
                                <div class="licencia-value" id="lblTipoLicencia">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Estado -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light">
                            <div class="info-card-icon bg-success bg-opacity-10 text-success">
                                <i class="ph ph-circle"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="licencia-label">Estado</div>
                                <div class="licencia-value" id="lblEstado">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Razón Social -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light">
                            <div class="info-card-icon bg-info bg-opacity-10 text-info">
                                <i class="ph ph-building"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="licencia-label">Razón Social</div>
                                <div class="licencia-value" id="lblRazonSocial">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Contacto -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light">
                            <div class="info-card-icon bg-warning bg-opacity-10 text-warning">
                                <i class="ph ph-user"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="licencia-label">Contacto</div>
                                <div class="licencia-value" id="lblContacto">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Registro -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light">
                            <div class="info-card-icon bg-secondary bg-opacity-10 text-secondary">
                                <i class="ph ph-calendar"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="licencia-label">Fecha de Registro</div>
                                <div class="licencia-value" id="lblFechaRegistro">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Prueba / Vencimiento -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light">
                            <div class="info-card-icon bg-danger bg-opacity-10 text-danger">
                                <i class="ph ph-hourglass"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="licencia-label">Vencimiento</div>
                                <div class="licencia-value" id="lblVencimiento">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Teléfono Contacto -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light">
                            <div class="info-card-icon bg-primary bg-opacity-10 text-primary">
                                <i class="ph ph-phone"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="licencia-label">Teléfono</div>
                                <div class="licencia-value" id="lblTelefono">-</div>
                            </div>
                        </div>
                    </div>

                    <!-- Prueba -->
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="d-flex align-items-center gap-3 p-3 rounded-3 bg-light">
                            <div class="info-card-icon bg-purple bg-opacity-10" style="color: #8b5cf6;">
                                <i class="ph ph-flask"></i>
                            </div>
                            <div class="min-w-0">
                                <div class="licencia-label">Licencia de Prueba</div>
                                <div class="licencia-value" id="lblEsPrueba">-</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payments Grid Section -->
        <div class="card shadow-sm licencia-card">
            <div class="card-body">
                <h5 class="section-title mb-4">
                    <i class="ph ph-currency-dollar me-2"></i>Historial de Pagos
                </h5>

                <div class="table-responsive">
                    <table id="tblPagosLicencia" class="table table-hover table-striped w-100">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Monto</th>
                                <th>Fecha de Registro</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/views/licencia.js" asp-append-version="true"></script>
}
