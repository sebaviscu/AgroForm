@model AplicacionesVM
@{
    ViewData["Title"] = "Reporte de Aplicaciones Agrícolas";
}

<div class="container-fluid py-3">
    <!-- ===== Header ===== -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-1 fw-bold">
                <i class="ph-drop-half me-2 text-primary"></i>Reporte de Aplicaciones Agrícolas
            </h4>
            <p class="text-muted mb-0 small">Pulverizaciones y Fertilizaciones - Análisis completo de insumos y costos</p>
        </div>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            <button class="btn btn-outline-success btn-sm" onclick="exportarExcel()" title="Exportar a Excel">
                <i class="ph ph-file-xls"></i> Excel
            </button>
            <button class="btn btn-outline-danger btn-sm" onclick="exportarPDF()" title="Exportar a PDF">
                <i class="ph ph-file-pdf"></i> PDF
            </button>
            <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="modal" data-bs-target="#helpModal">
                <i class="ph ph-question me-1"></i> Ayuda
            </button>
        </div>
    </div>

    <!-- ===== Filtros ===== -->
    <div class="card mb-3">
        <div class="card-body py-3">
            <div class="row g-2">
                <div class="col-md-2 col-sm-6">
                    <label class="form-label small fw-semibold">Campaña</label>
                    <select id="filtroCampania" class="form-select form-select-sm">
                        <option value="">Todas</option>
                        @foreach (var c in Model.Campanias)
                        {
                            <option value="@c.Id">@c.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label small fw-semibold">Campo</label>
                    <select id="filtroCampo" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        @foreach (var c in Model.Campos)
                        {
                            <option value="@c.Id">@c.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label small fw-semibold">Lote</label>
                    <select id="filtroLote" class="form-select form-select-sm">
                        <option value="">Todos</option>
                    </select>
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label small fw-semibold">Cultivo</label>
                    <select id="filtroCultivo" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        @foreach (var c in Model.Cultivos)
                        {
                            <option value="@c.Id">@c.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label small fw-semibold">Tipo</label>
                    <select id="filtroTipoAplicacion" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        <option value="3">Pulverización</option>
                        <option value="4">Fertilización</option>
                    </select>
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label small fw-semibold">Producto</label>
                    <select id="filtroProducto" class="form-select form-select-sm">
                        <option value="">Todos</option>
                        @foreach (var p in Model.Productos)
                        {
                            <option value="@p.Id">@p.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label small fw-semibold">Fecha Desde</label>
                    <input type="date" id="filtroFechaDesde" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2 col-sm-6">
                    <label class="form-label small fw-semibold">Fecha Hasta</label>
                    <input type="date" id="filtroFechaHasta" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary btn-sm w-100" onclick="cargarDatos()">
                        <i class="ph ph-magnifying-glass me-1"></i>Generar Reporte
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== Loading State ===== -->
    <div id="loadingState" class="text-center" style="display:none;">
        <div class="spinner-container">
            <div class="spinner-border text-primary" role="status" style="width:3rem;height:3rem;">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="text-muted mb-0">Generando reporte de aplicaciones...</p>
        </div>
    </div>

    <!-- ===== Empty State ===== -->
    <div id="emptyState" class="text-center" style="display:none;">
        <i class="ph ph-drop" style="font-size:4rem;opacity:0.3;"></i>
        <h5 class="mt-3 text-muted">No se encontraron aplicaciones</h5>
        <p class="text-muted small">Seleccione filtros y presione "Generar Reporte" para visualizar los datos.</p>
    </div>

    <!-- ===== Report Content ===== -->
    <div id="reportContent" style="display:none;">
        <!-- KPIs -->
        <div id="kpisSection" class="row g-2 mb-3"></div>

        <!-- Tabs -->
        <div class="card">
            <div class="card-header p-0 border-bottom-0">
                <ul class="nav nav-tabs-app px-3 pt-2" id="reporteTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="tab-dashboard" data-bs-toggle="tab" data-bs-target="#panel-dashboard" type="button" role="tab">
                            <i class="ph ph-gauge"></i>Dashboard
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-datos" data-bs-toggle="tab" data-bs-target="#panel-datos" type="button" role="tab">
                            <i class="ph ph-table"></i>Datos
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-timeline" data-bs-toggle="tab" data-bs-target="#panel-timeline" type="button" role="tab">
                            <i class="ph ph-clock-counter-clockwise"></i>Timeline
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-insumos" data-bs-toggle="tab" data-bs-target="#panel-insumos" type="button" role="tab">
                            <i class="ph ph-flask"></i>Insumos
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-graficos" data-bs-toggle="tab" data-bs-target="#panel-graficos" type="button" role="tab">
                            <i class="ph ph-chart-bar"></i>Gráficos
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="tab-trazabilidad" data-bs-toggle="tab" data-bs-target="#panel-trazabilidad" type="button" role="tab">
                            <i class="ph ph-tree-structure"></i>Trazabilidad
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body tab-content">
                <!-- Panel: Dashboard -->
                <div class="tab-pane fade show active" id="panel-dashboard" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-lg-8">
                            <div class="card h-100">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-chart-bar me-1"></i>Costos por Producto
                                </div>
                                <div class="card-body">
                                    <div class="chart-container">
                                        <canvas id="chartCostosProducto"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="card h-100">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-chart-pie-slice me-1"></i>Distribución por Tipo
                                </div>
                                <div class="card-body">
                                    <div class="chart-container">
                                        <canvas id="chartDistribucionTipo"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-trend-up me-1"></i>Evolución Temporal
                                </div>
                                <div class="card-body">
                                    <div class="chart-container">
                                        <canvas id="chartTimelineApps"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-barbell me-1"></i>Comparativa por Campaña
                                </div>
                                <div class="card-body">
                                    <div class="chart-container">
                                        <canvas id="chartComparativaCampania"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-map-pin me-1"></i>Comparativa por Campo
                                </div>
                                <div class="card-body">
                                    <div class="chart-container">
                                        <canvas id="chartComparativaCampo"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Panel: Datos (Tabla Principal) -->
                <div class="tab-pane fade" id="panel-datos" role="tabpanel">
                    <div id="tablaContainer">
                        <div class="table-responsive">
                            <table class="table table-reporte table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th class="sortable" data-col="Fecha">
                                            <i class="ph-calendar me-1"></i>Fecha <i class="ph-caret-down sort-icon"></i>
                                        </th>
                                        <th class="sortable" data-col="TipoActividad">Tipo <i class="ph-caret-down sort-icon"></i></th>
                                        <th class="sortable" data-col="Lote">Lote <i class="ph-caret-down sort-icon"></i></th>
                                        <th class="sortable" data-col="Campo">Campo <i class="ph-caret-down sort-icon"></i></th>
                                        <th class="sortable" data-col="Cultivo">Cultivo <i class="ph-caret-down sort-icon"></i></th>
                                        <th class="sortable" data-col="ProductoAplicado">Producto <i class="ph-caret-down sort-icon"></i></th>
                                        <th class="sortable" data-col="Dosis">Dosis <i class="ph-caret-down sort-icon"></i></th>
                                        <th class="sortable" data-col="CantidadTotal">Cantidad <i class="ph-caret-down sort-icon"></i></th>
                                        <th class="sortable" data-col="CostoARS">Costo ARS <i class="ph-caret-down sort-icon"></i></th>
                                        <th class="sortable" data-col="CostoUSD">Costo USD <i class="ph-caret-down sort-icon"></i></th>
                                        <th class="sortable" data-col="Responsable">Responsable <i class="ph-caret-down sort-icon"></i></th>
                                        <th>Observación</th>
                                    </tr>
                                </thead>
                                <tbody id="tablaBody"></tbody>
                            </table>
                        </div>
                        <div id="paginacionContainer" class="d-flex justify-content-between align-items-center mt-3"></div>
                    </div>
                </div>

                <!-- Panel: Timeline -->
                <div class="tab-pane fade" id="panel-timeline" role="tabpanel">
                    <div class="row">
                        <div class="col-12 mb-3">
                            <p class="text-muted small mb-0">
                                <i class="ph-info me-1"></i>Historial de aplicaciones ordenado por fecha (últimas 50).
                            </p>
                        </div>
                        <div class="col-12">
                            <div id="timelineContainer" class="timeline-vertical"></div>
                        </div>
                    </div>
                </div>

                <!-- Panel: Insumos -->
                <div class="tab-pane fade" id="panel-insumos" role="tabpanel">
                    <div class="row">
                        <div class="col-12 mb-3">
                            <p class="text-muted small mb-0">
                                <i class="ph-info me-1"></i>Análisis de consumo de insumos agrupado por producto.
                            </p>
                        </div>
                        <div class="col-12">
                            <div class="table-responsive">
                                <table class="table table-reporte table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Producto</th>
                                            <th>Tipo</th>
                                            <th>Cantidad Total</th>
                                            <th>Unidad</th>
                                            <th>Costo ARS</th>
                                            <th>Costo USD</th>
                                            <th>Aplicaciones</th>
                                            <th>Lotes</th>
                                            <th>Cultivo Principal</th>
                                            <th>Campaña</th>
                                        </tr>
                                    </thead>
                                    <tbody id="insumosBody"></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Panel: Gráficos -->
                <div class="tab-pane fade" id="panel-graficos" role="tabpanel">
                    <div class="row g-3">
                        <div class="col-lg-6">
                            <div class="card">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-chart-bar me-1"></i>Costos por Producto
                                </div>
                                <div class="card-body">
                                    <div class="chart-container" style="min-height:350px;">
                                        <canvas id="chartCostosProductoFull"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="card">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-chart-pie-slice me-1"></i>Distribución por Tipo
                                </div>
                                <div class="card-body">
                                    <div class="chart-container" style="min-height:350px;">
                                        <canvas id="chartDistribucionTipoFull"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-trend-up me-1"></i>Evolución Temporal de Aplicaciones
                                </div>
                                <div class="card-body">
                                    <div class="chart-container" style="min-height:350px;">
                                        <canvas id="chartTimelineAppsFull"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="card">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-barbell me-1"></i>Comparativa por Campaña
                                </div>
                                <div class="card-body">
                                    <div class="chart-container" style="min-height:350px;">
                                        <canvas id="chartComparativaCampaniaFull"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="card">
                                <div class="card-header bg-transparent fw-semibold">
                                    <i class="ph-map-pin me-1"></i>Comparativa por Campo
                                </div>
                                <div class="card-body">
                                    <div class="chart-container" style="min-height:350px;">
                                        <canvas id="chartComparativaCampoFull"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Panel: Trazabilidad -->
                <div class="tab-pane fade" id="panel-trazabilidad" role="tabpanel">
                    <div class="row">
                        <div class="col-12 mb-3">
                            <p class="text-muted small mb-0">
                                <i class="ph-info me-1"></i>Auditoría completa de aplicaciones: quién, cuándo, qué, dónde, por qué y costo.
                            </p>
                        </div>
                        <div class="col-12">
                            <div id="trazabilidadContainer" class="trace-timeline"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Help Modal -->
<div class="modal fade" id="helpModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header modal-header-app">
                <h5 class="modal-title"><i class="ph-question me-2"></i>Ayuda - Reporte de Aplicaciones</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="accordion" id="helpAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#helpFiltros">
                                Filtros disponibles
                            </button>
                        </h2>
                        <div id="helpFiltros" class="accordion-collapse collapse show" data-bs-parent="#helpAccordion">
                            <div class="accordion-body small">
                                Use los filtros para acotar el reporte por campaña, campo, lote, cultivo, tipo de aplicación, producto y rango de fechas.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#helpKpis">
                                Indicadores (KPIs)
                            </button>
                        </h2>
                        <div id="helpKpis" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
                            <div class="accordion-body small">
                                Los KPIs muestran total de aplicaciones, litros/kg aplicados, costos totales y por hectárea, productos más utilizados y superficie tratada.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#helpTabs">
                                Pestañas del reporte
                            </button>
                        </h2>
                        <div id="helpTabs" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
                            <div class="accordion-body small">
                                <strong>Dashboard:</strong> Vista ejecutiva con gráficos principales.<br/>
                                <strong>Datos:</strong> Tabla detallada con todas las aplicaciones, ordenable y paginada.<br/>
                                <strong>Timeline:</strong> Línea de tiempo vertical con el historial de aplicaciones.<br/>
                                <strong>Insumos:</strong> Análisis de consumo agrupado por producto.<br/>
                                <strong>Gráficos:</strong> Conjunto completo de visualizaciones.<br/>
                                <strong>Trazabilidad:</strong> Auditoría completa de cada aplicación.
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#helpExport">
                                Exportación
                            </button>
                        </h2>
                        <div id="helpExport" class="accordion-collapse collapse" data-bs-parent="#helpAccordion">
                            <div class="accordion-body small">
                                Use los botones <strong>Excel</strong> y <strong>PDF</strong> en la esquina superior derecha para exportar los datos.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Scripts de librerías externas -->
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>

    <!-- Pasar datos del servidor al cliente -->
    <script>
        window.aplicacionesModel = {
            campanias: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Campanias.Select(c => new { c.Id, c.Nombre }))),
            campos: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Campos.Select(c => new { c.Id, c.Nombre }))),
            cultivos: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Cultivos.Select(c => new { c.Id, c.Nombre }))),
            productos: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Productos.Select(p => new { p.Id, p.Nombre })))
        };
    </script>
    <script src="~/js/views/reporteAplicaciones.js"></script>
}
