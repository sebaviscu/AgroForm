@model ReporteComparativaVM
@{
    ViewData["Title"] = "Comparativa de Campos / Lotes";
}

<style>
    .summary-card {
        border-radius: 12px;
        transition: transform 0.2s;
    }
    .summary-card:hover {
        transform: translateY(-2px);
    }
    .summary-card .card-body {
        padding: 1rem 1.25rem;
    }
    .summary-card .icon-circle {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    .ranking-badge {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.8rem;
    }
    .ranking-1 { background: #ffd700; color: #000; }
    .ranking-2 { background: #c0c0c0; color: #000; }
    .ranking-3 { background: #cd7f32; color: #fff; }
    .chart-container {
        position: relative;
        height: 300px;
        width: 100%;
    }
    .filter-section {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 1rem;
    }
    .heatmap-cell {
        padding: 0.5rem;
        text-align: center;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.85rem;
    }
    .heatmap-high { background: #1a9850; color: white; }
    .heatmap-mid-high { background: #91cf60; color: #333; }
    .heatmap-mid { background: #fee08b; color: #333; }
    .heatmap-mid-low { background: #fc8d59; color: #333; }
    .heatmap-low { background: #d73027; color: white; }
    .heatmap-none { background: #e9ecef; color: #999; }
    .table-compact td, .table-compact th {
        padding: 0.4rem 0.5rem;
        font-size: 0.85rem;
        vertical-align: middle;
    }
    .table-compact th {
        white-space: nowrap;
        cursor: pointer;
        user-select: none;
        position: relative;
    }
    .table-compact th:hover {
        background-color: #e9ecef;
    }
    .table-compact th.sort-asc,
    .table-compact th.sort-desc {
        background-color: #d4edda;
        color: #155724;
    }
    .sort-icon {
        font-size: 0.7rem;
        margin-left: 2px;
    }
    .lote-name {
        font-weight: 600;
    }
    .campo-name {
        font-size: 0.75rem;
        color: #6c757d;
    }
</style>

<div class="container-fluid">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 fw-bold mb-1">
                <i class="ph ph-chart-bar text-success me-2"></i>Comparativa de Campos / Lotes
            </h1>
            <p class="text-muted mb-0 small">Compare rendimiento, costos y eficiencia entre lotes y campos</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <!-- Selector de Moneda -->
            <div class="d-flex align-items-center gap-2">
                <label for="selectorMoneda" class="form-label fw-semibold mb-0 small">Moneda:</label>
                <select id="selectorMoneda" class="form-select form-select-sm" style="width: auto;" onchange="cambiarMoneda()">
                    <option value="ARS">Pesos (ARS)</option>
                    <option value="USD">Dólares (USD)</option>
                </select>
            </div>
            <button id="btnExportarExcel" class="btn btn-outline-success btn-sm me-1">
                <i class="ph ph-file-xls me-1"></i> Exportar Excel
            </button>
            <button id="btnRefrescar" class="btn btn-primary btn-sm">
                <i class="ph ph-arrows-clockwise me-1"></i> Actualizar
            </button>
        </div>
    </div>

    <!-- Filtros -->
    <div class="filter-section mb-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label for="filtroCampo" class="form-label small fw-semibold">Campo</label>
                <select id="filtroCampo" class="form-select form-select-sm">
                    <option value="">Todos los campos</option>
                    @foreach (var c in Model.Campos)
                    {
                        <option value="@c.Id">@c.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label for="filtroLote" class="form-label small fw-semibold">Lote</label>
                <select id="filtroLote" class="form-select form-select-sm">
                    <option value="">Todos los lotes</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="filtroCultivo" class="form-label small fw-semibold">Cultivo</label>
                <select id="filtroCultivo" class="form-select form-select-sm">
                    <option value="">Todos los cultivos</option>
                    @foreach (var c in Model.Cultivos)
                    {
                        <option value="@c.Id">@c.Nombre</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-1">
                <button id="btnFiltrar" class="btn btn-primary btn-sm flex-fill">
                    <i class="ph ph-funnel me-1"></i> Filtrar
                </button>
                <button id="btnLimpiarFiltros" class="btn btn-outline-secondary btn-sm">
                    <i class="ph ph-x"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Tarjetas de Resumen -->
    <div class="row g-2 mb-3" id="summaryCards">
        <div class="col-md-3 col-6">
            <div class="card summary-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="ph ph-map-trifold"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Total Lotes</div>
                            <div class="fw-bold fs-5" id="resumen-totalLotes">@Model.Resumen.TotalLotes</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card summary-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="ph ph-trend-up"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Rend. Promedio</div>
                            <div class="fw-bold fs-5" id="resumen-rendimientoPromedio">
                                @(Model.Resumen.RendimientoPromedio.HasValue ? $"{Model.Resumen.RendimientoPromedio:N2} tn/ha" : "-")
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card summary-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-warning bg-opacity-10 text-warning">
                            <i class="ph ph-trophy"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Mejor Lote</div>
                            <div class="fw-bold fs-6 text-truncate" style="max-width: 140px;" id="resumen-mejorLote" title="@Model.Resumen.LoteMejorRendimiento">
                                @(Model.Resumen.LoteMejorRendimiento ?? "-")
                            </div>
                            <div class="small text-success" id="resumen-mejorRendimiento">
                                @(Model.Resumen.RendimientoMaximo.HasValue ? $"{Model.Resumen.RendimientoMaximo:N2} tn/ha" : "")
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card summary-card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-circle bg-info bg-opacity-10 text-info">
                            <i class="ph ph-currency-circle-dollar"></i>
                        </div>
                        <div>
                            <div class="text-muted small">Costo Prom./Ha</div>
                            <div class="fw-bold fs-5">
                                <span class="valor-ars" id="resumen-costoPromedio-ars">
                                    @(Model.Resumen.CostoPromedioPorHa.HasValue ? $"${Model.Resumen.CostoPromedioPorHa:N2}" : "-")
                                </span>
                                <span class="valor-usd" id="resumen-costoPromedio-usd" style="display: none;">-</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráficos -->
    <div class="row g-2 mb-3">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-2">
                    <h6 class="mb-0 fw-semibold">
                        <i class="ph ph-chart-bar me-1"></i>Rendimiento por Lote (tn/ha)
                    </h6>
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="chartRendimiento"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-2">
                    <h6 class="mb-0 fw-semibold">
                        <i class="ph ph-chart-pie me-1"></i>Costo por Lote <span id="chartCostosTitle">(ARS)</span>
                    </h6>
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="chartCostos"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Heatmap de Rendimiento -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-semibold">
                <i class="ph ph-grid-four me-1"></i>Heatmap de Rendimiento por Lote
            </h6>
            <div class="d-flex align-items-center gap-2 small">
                <span class="heatmap-cell heatmap-high" style="padding: 2px 8px;">Alto</span>
                <span class="heatmap-cell heatmap-mid" style="padding: 2px 8px;">Medio</span>
                <span class="heatmap-cell heatmap-low" style="padding: 2px 8px;">Bajo</span>
                <span class="heatmap-cell heatmap-none" style="padding: 2px 8px;">Sin datos</span>
            </div>
        </div>
        <div class="card-body">
            <div id="heatmapContainer" class="d-flex flex-wrap gap-2">
                <!-- Se llena dinámicamente -->
            </div>
        </div>
    </div>

    <!-- Tabla de datos -->
    <div class="card shadow-sm">
        <div class="card-header bg-white py-2">
            <h6 class="mb-0 fw-semibold">
                <i class="ph ph-table me-1"></i>Datos Comparativos
            </h6>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tblComparativa" class="table table-striped table-hover table-compact mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#<span class="sort-icon"></span></th>
                            <th>Campo<span class="sort-icon"></span></th>
                            <th>Lote<span class="sort-icon"></span></th>
                            <th>Superficie (Ha)<span class="sort-icon"></span></th>
                            <th>Cultivo<span class="sort-icon"></span></th>
                            <th>Siembra<span class="sort-icon"></span></th>
                            <th>Cosecha<span class="sort-icon"></span></th>
                            <th>Rend. (tn/ha)<span class="sort-icon"></span></th>
                            <th>Rend. Total (tn)<span class="sort-icon"></span></th>
                            <th>Fert. (kg/ha)<span class="sort-icon"></span></th>
                            <th>Pulv. (L/ha)<span class="sort-icon"></span></th>
                            <th>Labores<span class="sort-icon"></span></th>
                            <th>Costo Total <span class="valor-ars">($)</span><span class="valor-usd" style="display: none;">(US$)</span><span class="sort-icon"></span></th>
                            <th>Costo/Ha <span class="valor-ars">($)</span><span class="valor-usd" style="display: none;">(US$)</span><span class="sort-icon"></span></th>
                        </tr>
                    </thead>
                    <tbody id="tablaBody">
                        <!-- Se llena dinámicamente -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

@section Scripts {
    <script src="~/js/views/reporteComparativa.js" asp-append-version="true"></script>
}
