@model RendimientoCosechaVM
@{
    ViewData["Title"] = "Rendimiento de Cosecha";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-1 fw-bold">
                <i class="ph ph-tractor me-2"></i>Rendimiento de Cosecha
            </h4>
            <p class="text-muted mb-0 small">Análisis detallado de rendimientos por lote, campaña y cultivo</p>
        </div>
        <div>
            <button class="btn btn-outline-secondary btn-sm me-2" onclick="exportarExcel()" title="Exportar a Excel">
                <i class="ph ph-file-xls me-1"></i>Excel
            </button>
            <button class="btn btn-outline-secondary btn-sm me-2" onclick="exportarPDF()" title="Exportar a PDF">
                <i class="ph ph-file-pdf me-1"></i>PDF
            </button>
            <button class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#ayudaModal" title="Ayuda">
                <i class="ph ph-question me-1"></i> Ayuda
            </button>
        </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Campaña</label>
                    <select id="filtroCampania" class="form-select form-select-sm">
                        <option value="">Todas</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Campo</label>
                    <select id="filtroCampo" class="form-select form-select-sm">
                        <option value="">Todos</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Lote</label>
                    <select id="filtroLote" class="form-select form-select-sm">
                        <option value="">Todos</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Cultivo</label>
                    <select id="filtroCultivo" class="form-select form-select-sm">
                        <option value="">Todos</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Desde</label>
                    <input type="date" id="filtroFechaDesde" class="form-control form-control-sm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-semibold">Hasta</label>
                    <input type="date" id="filtroFechaHasta" class="form-control form-control-sm" />
                </div>
                <div class="col-12 mt-2">
                    <button class="btn btn-primary btn-sm" onclick="cargarDatos()">
                        <i class="ph ph-magnifying-glass me-1"></i>Generar Reporte
                    </button>
                    <button class="btn btn-outline-secondary btn-sm ms-2" onclick="limpiarFiltros()">
                        <i class="ph ph-x-circle me-1"></i>Limpiar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Loading State -->
    <div id="loadingState" class="loading-container" style="display:none;">
        <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Cargando...</span>
        </div>
        <p class="text-muted">Generando reporte de rendimiento...</p>
    </div>

    <!-- Empty State -->
    <div id="emptyState" class="loading-container" style="display:none;">
        <i class="ph ph-database display-1 text-muted mb-3"></i>
        <h5 class="text-muted">Sin datos disponibles</h5>
        <p class="text-muted small">No se encontraron registros de cosecha para los filtros seleccionados.</p>
    </div>

    <!-- Report Data -->
    <div id="reportData" style="display:none;">
        <!-- KPI Cards -->
        <div id="kpiContainer" class="row g-3 mb-4"></div>

        <!-- Tabs -->
        <div class="card">
            <div class="card-header p-0">
                <ul class="nav nav-tabs-app px-3" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabResumen" type="button">
                            <i class="ph ph-chart-bar"></i>Resumen
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabTabla" type="button">
                            <i class="ph ph-table"></i>Datos
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabGraficos" type="button">
                            <i class="ph ph-barricade"></i>Gráficos
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabEvolucion" type="button">
                            <i class="ph ph-trend-up"></i>Evolución
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabIndicadores" type="button">
                            <i class="ph ph-lightbulb"></i>Indicadores
                            <span id="indicadorCount" class="badge bg-warning ms-1">0</span>
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content">
                    <!-- Tab: Resumen -->
                    <div class="tab-pane fade show active" id="tabResumen">
                        <div id="resumenContainer"></div>
                    </div>
                    <!-- Tab: Tabla de Datos -->
                    <div class="tab-pane fade" id="tabTabla">
                        <div id="tablaContainer"></div>
                        <div id="paginacionContainer"></div>
                    </div>
                    <!-- Tab: Gráficos -->
                    <div class="tab-pane fade" id="tabGraficos">
                        <div id="graficosContainer"></div>
                    </div>
                    <!-- Tab: Evolución -->
                    <div class="tab-pane fade" id="tabEvolucion">
                        <div id="evolucionContainer"></div>
                    </div>
                    <!-- Tab: Indicadores -->
                    <div class="tab-pane fade" id="tabIndicadores">
                        <div id="indicadoresContainer"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Help Modal -->
<div class="modal fade" id="ayudaModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header modal-header-app">
                <h5 class="modal-title"><i class="ph ph-question me-2"></i>Ayuda: Reporte de Rendimiento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="accordion" id="ayudaAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#ayudaFiltros">
                                Filtros
                            </button>
                        </h2>
                        <div id="ayudaFiltros" class="accordion-collapse collapse show" data-bs-parent="#ayudaAccordion">
                            <div class="accordion-body">
                                <p>Utiliza los filtros para acotar los datos del reporte:</p>
                                <ul>
                                    <li><strong>Campaña</strong>: Selecciona una campaña específica o "Todas" para ver el histórico completo.</li>
                                    <li><strong>Campo / Lote</strong>: Filtra por campo o lote específico.</li>
                                    <li><strong>Cultivo</strong>: Filtra por tipo de cultivo (Soja, Maíz, Trigo, etc.).</li>
                                    <li><strong>Fecha</strong>: Rango de fechas de cosecha.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ayudaKPI">
                                KPIs
                            </button>
                        </h2>
                        <div id="ayudaKPI" class="accordion-collapse collapse" data-bs-parent="#ayudaAccordion">
                            <div class="accordion-body">
                                <ul>
                                    <li><strong>Rendimiento Promedio</strong>: Media de rendimiento en tn/ha de todos los lotes.</li>
                                    <li><strong>Mejor/Peor Lote</strong>: Lotes con mayor y menor rendimiento.</li>
                                    <li><strong>Producción Total</strong>: Suma de producción en toneladas.</li>
                                    <li><strong>Superficie Cosechada</strong>: Total de hectáreas cosechadas.</li>
                                    <li><strong>Humedad Promedio</strong>: Humedad del grano al momento de cosecha.</li>
                                    <li><strong>Variación vs Campaña Anterior</strong>: Cambio porcentual del rendimiento promedio.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ayudaTablas">
                                Tablas y Rankings
                            </button>
                        </h2>
                        <div id="ayudaTablas" class="accordion-collapse collapse" data-bs-parent="#ayudaAccordion">
                            <div class="accordion-body">
                                <p>La tabla de datos permite ordenar por cualquier columna haciendo clic en el encabezado. Los rankings muestran el top 10 de lotes por rendimiento.</p>
                                <p>Puedes exportar los datos a Excel o PDF usando los botones de la barra superior.</p>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ayudaGraficos">
                                Gráficos
                            </button>
                        </h2>
                        <div id="ayudaGraficos" class="accordion-collapse collapse" data-bs-parent="#ayudaAccordion">
                            <div class="accordion-body">
                                <ul>
                                    <li><strong>Rendimiento por Cultivo</strong>: Distribución del rendimiento promedio por tipo de cultivo (torta).</li>
                                    <li><strong>Rendimiento por Campaña</strong>: Evolución del rendimiento promedio por campaña (barras).</li>
                                    <li><strong>Rendimiento por Campo</strong>: Comparativa de rendimiento entre campos (barras).</li>
                                    <li><strong>Evolución Histórica</strong>: Línea de rendimiento y humedad a través de las campañas.</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#ayudaIndicadores">
                                Indicadores Inteligentes
                            </button>
                        </h2>
                        <div id="ayudaIndicadores" class="accordion-collapse collapse" data-bs-parent="#ayudaAccordion">
                            <div class="accordion-body">
                                <p>Los indicadores inteligentes analizan automáticamente los datos y generan alertas y recomendaciones basadas en:</p>
                                <ul>
                                    <li>Rendimiento vs promedio general</li>
                                    <li>Humedad del grano fuera de rango</li>
                                    <li>Variación interanual significativa</li>
                                    <li>Brecha entre mejor y peor lote</li>
                                    <li>Cobertura de datos registrados</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Pass server-side ViewModel data to JavaScript -->
<script>
    window.rendimientoCosechaModel = {
        campanias: @Html.Raw(Json.Serialize(Model?.Campanias?.Select(c => new { id = c.Id, nombre = c.Nombre }))),
        campos: @Html.Raw(Json.Serialize(Model?.Campos?.Select(c => new { id = c.Id, nombre = c.Nombre }))),
        cultivos: @Html.Raw(Json.Serialize(Model?.Cultivos?.Select(c => new { id = c.Id, nombre = c.Nombre })))
    };
</script>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
    <script src="~/js/views/reporteCosecha.js" asp-append-version="true"></script>
}
