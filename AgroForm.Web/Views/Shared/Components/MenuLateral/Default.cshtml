<style>
    #sidebar {
        display: flex;
        flex-direction: column;
        height: 100vh;
        overflow: hidden;
    }

    .sidebar-content {
        flex: 1;
        overflow-y: auto;
    }

    .sidebar-footer {
        border-top: 1px solid rgba(255,255,255,0.1);
    }

    #sidebar.collapsed .sidebar-footer span {
        display: none !important;
    }

    #sidebar.collapsed .sidebar-footer .dropdown-menu {
        left: 60px !important;
    }
</style>

