                    <i class="ph ph-clipboard-text me-3"></i>
                    <span>Gestión</span>
                </a>
                <ul class="collapse list-unstyled" id="gestionSubmenu">
                    <li>
                        <a href="/Actividad/Index" class="sidebar-subitem">
