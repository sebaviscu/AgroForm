<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AgroLab</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">

    <link rel="stylesheet" href="https://cdn.datatables.net/2.2.2/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.2.1/css/buttons.bootstrap5.min.css">

    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">
    <link rel="manifest" href="~/manifest.json">
    <link rel="icon" href="~/images/android-launchericon-72-72.png" type="image/png" />

    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/reports.css" asp-append-version="true" />
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black">
    <meta name="apple-mobile-web-app-title" content="AgroApp">
    <link rel="apple-touch-icon" href="~/images/android-launchericon-192-192.png">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dark-theme.css" asp-append-version="true" />
    
    <!-- Trial Banner Styles (sidebar) -->
    <style>
        .trial-banner {
            padding: 8px 12px;
            font-size: 0.75rem;
            font-weight: 500;
            background-color: #fff3cd;
            color: #856404;
            border-top: 1px solid #ffc107;
            border-bottom: 1px solid #ffc107;
            text-align: center;
            letter-spacing: 0.3px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .trial-banner-expired {
            background-color: #f8d7da;
            color: #721c24;
            border-top-color: #f5c6cb;
            border-bottom-color: #f5c6cb;
        }
        /* Dark theme support */
        [data-theme="dark"] .trial-banner {
            background-color: rgba(61, 50, 0, 0.9);
            color: #ffd700;
            border-top-color: #6b5900;
            border-bottom-color: #6b5900;
        }
        [data-theme="dark"] .trial-banner-expired {
            background-color: rgba(61, 0, 0, 0.9);
            color: #ff6b6b;
            border-top-color: #6b0000;
            border-bottom-color: #6b0000;
        }
        /* Sidebar collapsed: hide text span */
        #sidebar.active .trial-banner span {
            display: none !important;
        }
        /* Mobile */
        @@media (max-width: 991.98px) {
            .trial-banner {
                padding: 6px 10px;
                font-size: 0.7rem;
            }
        }
    </style>
    
    <!-- Script para prevenir parpadeo de tema -->
    <script>
        (function() {
            var theme = localStorage.getItem('theme') || 'light';
            if (theme === 'dark') {
                document.documentElement.setAttribute('data-theme', 'dark');
            }
        })();
    </script>
</head>
<body>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Wrapper -->
    <div class="wrapper">
        <!-- Sidebar Overlay para móvil -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- Sidebar -->
        @await Component.InvokeAsync("MenuLateral")

        <!-- Page Content -->
        <div id="content" class="content">

            <!-- Top Navbar -->
            <nav id="topNavbar" class="navbar navbar-expand-lg navbar-light bg-white border-bottom py-2">
                <div class="container-fluid" style="padding: 0px">
                    <!-- Mobile toggle button -->
                    <button type="button" id="sidebarCollapseMobile" class="btn btn-outline-secondary btn-sm d-lg-none me-2">
                        <i class="ph ph-list"></i>
                    </button>

                    <!-- Desktop toggle button -->
                    <button type="button" id="sidebarCollapse" class="btn btn-outline-secondary btn-sm d-none d-lg-block me-2">
                        <i class="ph ph-list"></i>
                    </button>

                    <!-- Espaciador izquierdo -->
                    <div class="d-none d-lg-block flex-grow-1"></div>

                    <!-- Campañas (centrado) -->
                    <div class="navbar-brand m-0 p-0 mx-lg-3 flex-grow-1 flex-lg-grow-0 text-center">
                        @await Component.InvokeAsync("Campanias")
                    </div>

                    <!-- Espaciador derecho -->
                    <div class="d-none d-lg-block flex-grow-1"></div>

                    <!-- Botones de acción -->
                    <div class="d-flex align-items-center ms-3 me-3">
                        <div class="dropdown">
                            <button class="btn btn-success btn-sm rounded-pill d-flex align-items-center justify-content-center"
                                    type="button"
                                    id="accionesDropdown"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                    style="height: 42px; padding: 0 18px;">
                                <i class="ph ph-plus" style="font-size: 20px;"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="accionesDropdown">
                                <li>
                                    <a class="dropdown-item d-flex align-items-center py-2" href="#" id="btnAddActividad">
                                        <i class="ph ph-tractor me-2 text-success"></i>
                                        <span>Labores</span>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center py-2" href="#" id="btnClima">
                                        <i class="ph ph-cloud-rain me-2 text-primary"></i>
                                        <span>Clima</span>
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item d-flex align-items-center py-2" href="#" id="btnGasto">
                                        <i class="ph ph-receipt me-2 text-danger"></i>
                                        <span>Gasto</span>
                                    </a>
                                </li>
                            </ul>
                        </div>

                    </div>
                </div>
            </nav>

            <main class="main-content">
                @RenderBody()
            </main>

            
        </div>
    </div>




    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script src="https://cdn.datatables.net/2.2.2/js/dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/2.2.2/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.1/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.1/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.53/vfs_fonts.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.1/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/3.2.1/js/buttons.print.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    
    <script src="https://unpkg.com/@@phosphor-icons/web"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/dark-theme.js" asp-append-version="true"></script>

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', function() {
                navigator.serviceWorker.register('/sw.js')
                    .then(function(registration) {
                        console.log('ServiceWorker registrado con éxito: ', registration.scope);
                    })
                    .catch(function(error) {
                        console.log('Error registrando ServiceWorker: ', error);
                    });
            });
        }
    </script>

    <script>
        // Función para abrir el modal de perfil
        function abrirModalPerfil(event) {
            event.preventDefault();
            
            // Obtener el ID del usuario desde los claims
            const userId = '@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';
            
            if (userId) {
                // Cargar datos del usuario
                fetch(`/Access/GetUserProfile/${userId}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            document.getElementById('usuarioId').value = data.data.id;
                            document.getElementById('nombre').value = data.data.nombre;
                            document.getElementById('email').value = data.data.email;
                            document.getElementById('phoneNumber').value = data.data.phoneNumber || '';
                            
                            // Mostrar el modal
                            const modal = new bootstrap.Modal(document.getElementById('perfilModal'));
                            modal.show();
                        } else {
                            toastr.error('Error al cargar el perfil del usuario');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        toastr.error('Error al cargar el perfil del usuario');
                    });
            }
        }

        // Función para guardar el perfil
        function guardarPerfil() {
            const form = document.getElementById('perfilForm');
            
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const userId = document.getElementById('usuarioId').value;
            const perfilData = {
                id: parseInt(userId),
                nombre: document.getElementById('nombre').value,
                email: document.getElementById('email').value,
                phoneNumber: document.getElementById('phoneNumber').value
            };

            fetch('/Access/UpdateUserProfile', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                },
                body: JSON.stringify(perfilData)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    toastr.success('Perfil actualizado correctamente');
                    
                    // Cerrar el modal
                    const modal = bootstrap.Modal.getInstance(document.getElementById('perfilModal'));
                    modal.hide();
                    
                    // Actualizar el nombre mostrado en el sidebar si cambió
                    setTimeout(() => {
                        location.reload();
                    }, 1000);
                } else {
                    toastr.error(data.message || 'Error al actualizar el perfil');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                toastr.error('Error al actualizar el perfil');
            });
        }

        // Función para mostrar mensaje de configuración
        function mostrarMensajeConfiguracion(event) {
            event.preventDefault();
            toastr.info('La funcionalidad de configuración estará disponible próximamente');
        }

        function abrirModalConfiguracion(event) {
            event.preventDefault();
            const modal = new bootstrap.Modal(document.getElementById('configModal'));
            modal.show();
        }

        // Las funciones applyTheme/setTheme ahora están centralizadas en dark-theme.js
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @await Component.InvokeAsync("ActividadRapida")

<!-- Modal Perfil de Usuario -->
<div class="modal fade" id="perfilModal" tabindex="-1" aria-labelledby="perfilModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header modal-header-app">
                <h5 class="modal-title" id="perfilModalLabel">
                    <i class="ph ph-user me-2"></i>Mi Perfil
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="perfilForm">
                    <input type="hidden" id="usuarioId" />
                    <div class="mb-3">
                        <label for="nombre" class="form-label">Nombre</label>
                        <input type="text" class="form-control" id="nombre" required>
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Email</label>
                        <input type="email" class="form-control" id="email" required disabled>
                    </div>
                    <div class="mb-3">
                        <label for="phoneNumber" class="form-label">Teléfono</label>
                        <input type="tel" class="form-control" id="phoneNumber">
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="guardarPerfil()">
                    <i class="ph ph-check-circle me-1"></i>Guardar Cambios
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Configuración -->
<div class="modal fade" id="configModal" tabindex="-1" aria-labelledby="configModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header modal-header-app">
                <h5 class="modal-title" id="configModalLabel">
                    <i class="ph ph-gear me-2"></i>Configuración
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div>
                        <div class="fw-semibold">Tema</div>
                        <div class="text-muted small">Elegí modo claro u oscuro</div>
                    </div>
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input" type="checkbox" role="switch" id="themeSwitchUser">
                        <label class="form-check-label" for="themeSwitchUser">Oscuro</label>
                    </div>
                </div>
                
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div>
                        <div class="fw-semibold">Tipo de Dólar</div>
                        <div class="text-muted small">Seleccione su tipo de dólar de referencia</div>
                    </div>
                    <div>
                        <select class="form-select form-select-sm" id="tipoDolarModal" style="width: 150px;">
                            <option value="">Cargando...</option>
                        </select>
                    </div>
                </div>
                
                <div class="text-center">
                    <button type="button" class="btn btn-primary btn-sm" onclick="guardarConfiguracionMoneda()">
                        <i class="ph ph-check-circle me-1"></i>Guardar Cambios
                    </button>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/layout.js" asp-append-version="true"></script>

<!-- Trial License Banner Script -->
<script>
$(document).ready(function () {
    $.ajax({
        url: '/Access/GetTrialLicenseInfo',
        type: 'GET',
        success: function (response) {
            var $banner = $('#trialBanner');
            if (response.success && response.esPrueba) {
                var $bannerText = $('#trialBannerText');
                var $bannerSubText = $('#trialBannerSubText');
                if (response.expirada) {
                    $bannerText.text('Licencia de prueba expirada');
                    $banner.addClass('trial-banner-expired');
                } else {
                    var dias = response.diasRestantes;
                    $bannerText.text('Licencia de prueba');
                    var subTexto = dias + ' d\u00eda' + (dias !== 1 ? 's' : '') + ' restante' + (dias !== 1 ? 's' : '');
                    $bannerSubText.text(subTexto);
                    $banner.removeClass('trial-banner-expired');
                }
                $banner.show();
            } else {
                $banner.hide();
            }
        },
        error: function () { }
    });
});
</script>

</body>
</html>